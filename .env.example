# Core
NODE_ENV=production
PORT=5000
# Railway: append ?sslmode=require if not included in the copied URL
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Auth
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string
JWT_ACCESS_EXPIRES_IN=1h
JWT_LEARNER_ACCESS_EXPIRES_IN=24h

# CORS — comma-separated frontend origins
CORS_ORIGINS=https://your-trainee-portal.example.com,https://your-hr-portal.example.com

# SCORM Cloud
SCORM_CLOUD_APP_ID=
SCORM_CLOUD_SECRET_KEY=
SCORM_CALLBACK_SECRET=change-me-to-a-long-random-webhook-secret
# Large SCORM ZIP uploads (295MB+ may need up to 2h locally; adjust on Railway)
SCORM_UPLOAD_TIMEOUT_MS=7200000

# Object storage (Tigris / S3-compatible)
AWS_ENDPOINT_URL=https://t3.storageapi.dev
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
AWS_REGION=auto

# Web Push (optional)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@yourdomain.com

# Seed (development / first deploy only)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-on-first-login

# Feature flags — keep false until real implementations exist
ENABLE_SSO=false
ENABLE_MFA=false
